# Copy this file to .env.firmware and fill in your values.
# .env.firmware is gitignored — never commit the real file.
#
# Used by: scripts/load_env.py (PlatformIO pre-build script)
# Each key overrides the matching #ifndef default in src/settings.h.

# ─── WiFi defaults (overridable at runtime via web UI / NVS) ─────────────────
WIFI_SSID_DEFAULT=your_wifi_ssid
WIFI_PASSWORD_DEFAULT=your_wifi_password

# ─── MQTT broker ──────────────────────────────────────────────────────────────
MQTT_HOST=mq.example.com
MQTT_PORT=18883

# ─── LTE ──────────────────────────────────────────────────────────────────────
LTE_APN=internet

# OTA_VERSION_URL is set per-environment in platformio.ini (not here).
