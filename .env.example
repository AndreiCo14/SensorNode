# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the real file.
#
# Used by: scripts/ota-upload.sh

# ─── OTA server (SCP upload target) ──────────────────────────────────────────
OTA_SSH_USER=your_username
OTA_SSH_ADDR=192.168.1.100
OTA_SSH_PORT=22
OTA_SERVER_PATH=/var/www/html/ota
OTA_BASE_URL=http://ota.example.com/ota

# ─── MQTT (mosquitto_pub OTA trigger, used only when CHIP_ID is passed) ───────
MQTT_HOST=mq.example.com
MQTT_PORT=18883
